---
import "../styles/global.css";
import Base from "../layouts/Base.astro";
import Greeting from "../components/Greeting";
---

<Base pageTitle="About The Web Master">
  <Greeting
    client:load
    messages={[
      "Hello",
      "Hej",
      "你好",
      "안녕하세요",
      "Bonjour",
      "Hei",
      "Hallo",
      "こんにちは",
      "مرحبا",
    ]}
  />

  <div class="h-card">
    <p>
      Hi! I'm
      <span class="p-name">Jia-Rou</span> and I'm from
      <span class="p-country-name">Taiwan</span>. I live in
      <span class="p-country-name">Sweden</span>
      But my online wearabouts are at
      <a class="u-url" rel="me" href="https://github.com/stillejiarou">GitHub</a
      >
      and
      <a class="u-url" rel="me" href="https://neocities.org/site/stillejiarou"
        >Neocities</a
      >.
      <span class="p-note">
        A fun fact about me is... I can't come up with any. And I don't know
        what more to say about myself, so I'll just make a bunch of lists about
        the things that I like!
      </span>
    </p>
  </div>
  <article class="h-feed flex-feed">
    <section class="h-entry flex-card">
      <h3>Music</h3>
      <ol>
        <li>Metal</li>
        <li>Hyper Pop</li>
        <li>Vocaloid</li>
        <li>K-pop</li>
        <li>Nu-Rock</li>
      </ol>
    </section>
    <section class="h-entry flex-card">
      <h3>Art tools</h3>
      <ol>
        <li>Regular Ballpoint pens</li>
        <li>Ica's Gridded "Kollegeblock"</li>
        <li>Washi-tape</li>
        <li>Brush Pens</li>
        <li>General Notebooks</li>
      </ol>
    </section>
    <section class="h-entry flex-card">
      <h3>Plants</h3>
      <ol>
        <li>Berries</li>
        <li>Orchids</li>
        <li>Lillies</li>
        <li>Lav</li>
        <li>Moss</li>
      </ol>
    </section>
    <section class="h-entry flex-card">
      <h3>Go Players</h3>
      <ol>
        <li>Hei Jia-Jia</li>
        <li>Cho Chikun</li>
        <li>Lee Sedol</li>
        <li>Ke Jie</li>
        <li>Lee Chang-Ho</li>
      </ol>
    </section>
    <section class="h-entry flex-card">
      <h3>Pokemon</h3>
      <ol>
        <li>Marshadow</li>
        <li>Alolan Vulpix</li>
        <li>Gyarados</li>
        <li>Nihilego</li>
        <li>Shiny Umbreon</li>
      </ol>
    </section>
    <section class="h-entry flex-card">
      <h3>Gaming</h3>
      <ol>
        <li>Genshin Impact</li>
        <li>Project Sekai</li>
        <li>Minecraft</li>
        <li>Omori</li>
        <li>Pokemon Sun and Moon</li>
      </ol>
    </section>
    <section class="h-entry flex-card">
      <h3>Musical Artists</h3>
      <ol>
        <li>BTS</li>
        <li>Palaye Royale</li>
        <li>Alice in Chains</li>
        <li>Metallica</li>
        <li>Nightcord at 25</li>
      </ol>
    </section>
    <section class="h-entry flex-card">
      <h3>Colors</h3>
      <ol>
        <li>
          <span style="background-color: midnightblue; color: white;"
            >Midnight Blue</span
          >
        </li>
        <li>
          <span style="background-color: lavenderblush; color: black;"
            >Lavender Blush</span
          >
        </li>
        <li>
          <span style="background-color: lightsteelblue; color: black;"
            >Light Steel Blue</span
          >
        </li>
        <li>
          <span style="background-color: aliceblue; color: black;"
            >Alice Blue</span
          >
        </li>
        <li>
          <span style="background-color: lightskyblue; color: black;"
            >Light Sky Blue</span
          >
        </li>
      </ol>
    </section>
    <section class="h-entry flex-card">
      <h3>Tags</h3>
      <ol>
        <li>&lt;article&gt;</li>
        <li>&lt;section&gt;</li>
        <li>&lt;main&gt;</li>
        <li>&lt;nav&gt;</li>
        <li>&lt;header&gt;</li>
      </ol>
    </section>
    <section class="h-entry flex-card">
      <h3>Animals</h3>
      <ol>
        <li>Jellyfish</li>
        <li>Python</li>
        <li>Hognoose Snake</li>
        <li>Elks</li>
